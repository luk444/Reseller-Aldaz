# URL pública del sitio (metadata / Open Graph)
NEXT_PUBLIC_SITE_URL=https://tu-dominio.com

# Telegram (botón hero + FAB)
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/TU_USUARIO

# Link de pago tarjeta crédito/débito
NEXT_PUBLIC_CARD_PAYMENT_URL=https://tu-enlace-de-pago.com

# Opcional: landing PREX o instrucciones
NEXT_PUBLIC_PREX_URL=https://prexcard.com

# --- Tasas (servidor, GET /api/exchange-rates) ---
# Intervalo de refresco en el servidor (ms). Por defecto 15 min.
# EXCHANGE_RATE_REFRESH_MS=900000

# Opcional: exchangerate.host con access_key (se intenta antes que open.er)
# EXCHANGERATE_HOST_ACCESS_KEY=

# Opcional: URLs DolarAPI (por defecto se usan las de dolarapi.com)
# DOLAR_BLUE_API_URL=https://dolarapi.com/v1/dolares/blue
# DOLARAPI_BR_URL=https://br.dolarapi.com/v1/cotacoes/usd
# DOLARAPI_CL_URL=https://cl.dolarapi.com/v1/cotizaciones/usd
# DOLARAPI_UY_URL=https://uy.dolarapi.com/v1/cotizaciones/usd
# DOLARAPI_CO_URL=https://co.dolarapi.com/v1/cotizaciones
# DOLARAPI_MX_URL=https://mx.dolarapi.com/v1/cotizaciones/usd
# DOLARAPI_BO_URL=https://bo.dolarapi.com/v1/dolares
# DOLARAPI_VE_URL=https://ve.dolarapi.com/v1/dolares
